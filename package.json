{
  "name": "easy-csp",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "homepage": "https://lleeoochen.github.io/easy-csp",
  "scripts": {
    "clean": "rm -rf node_modules/@easy-csp/ && rm -f package-lock.json && rm -f easy-csp-shared-types-1.0.0.tgz",
    "preinstall": "if [ -d ../easy-csp-shared-types ]; then npm pack ../easy-csp-shared-types; fi",
    "install:special": "npm run clean && npm run preinstall && npm install",
    "serve": "vite --host",
    "build": "vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "predeploy": "npm run build",
    "deploy": "gh-pages -d dist",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest --coverage"
  },
  "dependencies": {
    "@easy-csp/shared-types": "file:easy-csp-shared-types-1.0.0.tgz",
    "@reduxjs/toolkit": "^2.11.2",
    "@tailwindcss/vite": "^4.1.18",
    "@tanstack/react-query": "^5.90.21",
    "@types/uuid": "^10.0.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "firebase": "^10.0.0",
    "firebaseui": "^6.1.0",
    "lucide-react": "^0.562.0",
    "moment": "^2.30.1",
    "plaid": "^40.0.0",
    "react": "^19.2.0",
    "react-day-picker": "^9.14.0",
    "react-dom": "^19.2.0",
    "react-infinite-scroll-component": "^6.1.1",
    "react-plaid-link": "^4.1.1",
    "react-redux": "^9.2.0",
    "react-router-dom": "^7.11.0",
    "react-select": "^5.10.2",
    "recharts": "^3.8.1",
    "tailwind-merge": "^3.4.0",
    "tailwindcss": "^4.1.18",
    "uuid": "^13.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@testing-library/jest-dom": "^6.4.2",
    "@testing-library/react": "^15.0.0",
    "@testing-library/user-event": "^14.5.2",
    "@types/node": "^24.10.9",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "@vitest/ui": "^1.3.1",
    "@vitest/coverage-v8": "^1.3.1",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "gh-pages": "^6.3.0",
    "globals": "^16.5.0",
    "jsdom": "^24.0.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.46.4",
    "vite": "^8.0.7",
    "vitest": "^1.3.1"
  }
}
